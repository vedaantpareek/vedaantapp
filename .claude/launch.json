{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Remote Control Preview",
      "runtimeExecutable": "node",
      "runtimeArgs": ["preview-server.js"],
      "port": 3002
    },
    {
      "name": "Expo Dev Server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start"],
      "port": 8081
    },
    {
      "name": "Expo (iOS Simulator)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--ios"],
      "port": 8081
    },
    {
      "name": "Expo (Android Emulator)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--android"],
      "port": 8081
    }
  ]
}
